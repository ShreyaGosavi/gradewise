generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Year {
  FE
  SE
  TE
  BE
}

enum Department {
  CSE
  IT
  ME
  CIVIL
  EXTC
}

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

model Teacher {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())

  classTeacherOf     Class?              @relation("ClassTeacher")
  subjectAssignments SubjectAssignment[]
}

model Student {
  id           Int        @id @default(autoincrement())
  email        String     @unique
  name         String
  year         Year
  department   Department
  createdAt    DateTime   @default(now())

  studentClass StudentClass?
}

model Class {
  id         Int        @id @default(autoincrement())
  year       Year
  department Department
  division   String     // A, B, C

  createdAt  DateTime   @default(now())

  // one class → one class teacher (optional)
  classTeacherId Int?    @unique
  classTeacher   Teacher? @relation("ClassTeacher", fields: [classTeacherId], references: [id])

  subjectAssignments SubjectAssignment[]
  students           StudentClass[]

  // same year + dept + division can't be duplicated
  @@unique([year, department, division])
}

model Subject {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())

  subjectAssignments SubjectAssignment[]
}

model SubjectAssignment {
  id        Int     @id @default(autoincrement())

  teacherId Int
  subjectId Int
  classId   Int

  teacher   Teacher @relation(fields: [teacherId], references: [id])
  subject   Subject @relation(fields: [subjectId], references: [id])
  class     Class   @relation(fields: [classId], references: [id])

  // one subject in one class = one teacher only
  @@unique([subjectId, classId])
}

model StudentClass {
  id        Int     @id @default(autoincrement())

  studentId Int     @unique
  classId   Int

  student   Student @relation(fields: [studentId], references: [id])
  class     Class   @relation(fields: [classId], references: [id])
}