generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum Year {
  FE
  SE
  TE
  BE
}

enum Department {
  CSE
  IT
  ME
  CIVIL
  EXTC
}

enum MarksType {
  INSEM1
  INSEM2
  ENDSEM
  INTERNAL
  PRACTICAL
  ORAL
}

enum NoticeType {
  ASSIGNMENT
  TEST
  NOTICE
  EVENT
}

// ─── Models ──────────────────────────────────────────────

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

model Teacher {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  classTeacherOf     Class?              @relation("ClassTeacher")
  subjectAssignments SubjectAssignment[]
  attendances        Attendance[]
  notices            NoticeBoard[]
}

model Student {
  id         Int        @id @default(autoincrement())
  email      String     @unique
  password   String
  name       String
  year       Year
  department Department
  isActive  Boolean  @default(true)
  createdAt  DateTime   @default(now())

  studentClass      StudentClass?
  attendanceRecords AttendanceRecord[]
  marks             Marks[]
}

model Class {
  id         Int        @id @default(autoincrement())
  year       Year
  department Department
  division   String
  isActive  Boolean  @default(true)
  createdAt  DateTime   @default(now())

  classTeacherId Int?     @unique
  classTeacher   Teacher? @relation("ClassTeacher", fields: [classTeacherId], references: [id])

  subjectAssignments SubjectAssignment[]
  students           StudentClass[]
  attendances        Attendance[]
  marks              Marks[]
  notices            NoticeBoard[]

  @@unique([year, department, division])
}

model Subject {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  subjectAssignments SubjectAssignment[]
  attendances        Attendance[]
  marks              Marks[]
}

model SubjectAssignment {
  id        Int @id @default(autoincrement())

  teacherId Int
  subjectId Int
  classId   Int

  teacher Teacher @relation(fields: [teacherId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])

  @@unique([subjectId, classId])
}

model StudentClass {
  id        Int @id @default(autoincrement())

  studentId Int @unique
  classId   Int

  student Student @relation(fields: [studentId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])
}

model Attendance {
  id        Int      @id @default(autoincrement())
  date      DateTime
  lectureNo Int

  classId   Int
  subjectId Int
  teacherId Int

  class   Class   @relation(fields: [classId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
  teacher Teacher @relation(fields: [teacherId], references: [id])

  records   AttendanceRecord[]
  createdAt DateTime @default(now())

  @@unique([classId, subjectId, date, lectureNo])
}

model AttendanceRecord {
  id           Int     @id @default(autoincrement())
  attendanceId Int
  studentId    Int
  isPresent    Boolean @default(false)

  attendance Attendance @relation(fields: [attendanceId], references: [id])
  student    Student    @relation(fields: [studentId], references: [id])

  @@unique([attendanceId, studentId])
}

model Marks {
  id        Int       @id @default(autoincrement())
  studentId Int
  subjectId Int
  classId   Int
  type      MarksType
  obtained  Float
  total     Float

  student Student @relation(fields: [studentId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])

  createdAt DateTime @default(now())

  @@unique([studentId, subjectId, type])
}

model NoticeBoard {
  id        Int        @id @default(autoincrement())
  title     String
  content   String
  type      NoticeType
  dueDate   DateTime?

  classId   Int
  teacherId Int

  class   Class   @relation(fields: [classId], references: [id])
  teacher Teacher @relation(fields: [teacherId], references: [id])

  createdAt DateTime @default(now())
}